# ── REQUIRED IN PRODUCTION ──────────────────────────────────────────────────
# Database (PostgreSQL in prod, SQLite auto-created for local dev)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# HMAC secret for email verification & unsubscribe tokens
# MUST be set in production — app will refuse to start without it
VERIFY_SECRET=generate-a-random-secret-here

# Google Gemini (session generation)
GEMINI_API_KEY=your_gemini_api_key

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# ElevenLabs (Voice narration)
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Email reminders (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Jerome7 <hello@jerome7.com>

# Twitter/X (daily posting script)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Discord bot
